# ==============================================================================
# Reasoning-Aware Adaptive Routing for Hybrid GraphRAG — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your local setup.
# All variables are optional if you configure them directly in configs/config.yaml.

# --- LLM / OpenAI-compatible API ---
# API key for the OpenAI-compatible endpoint (e.g., vLLM, LM Studio, OpenAI).
# Set to "not-required" if your local server does not require authentication.
OPENAI_API_KEY=

# --- Neo4j Graph Database ---
# Connection details for Neo4j. Defaults are in configs/config.yaml.
# NEO4J_URI=neo4j://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# --- Ollama (optional) ---
# Ollama base URL if using Ollama as the LLM backend.
# OLLAMA_BASE_URL=http://localhost:11434
